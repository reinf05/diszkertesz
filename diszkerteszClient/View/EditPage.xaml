<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="diszkerteszClient.View.EditPage"
             Title="EditPage"
             xmlns:viewmodels="clr-namespace:diszkerteszClient.Viewmodels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewmodels:EditViewModel">
    <Grid>
        <Grid ColumnDefinitions="*,*"
              RowDefinitions="Auto,*,Auto"
              IsVisible="{Binding IsNotImage}">

            <ImageButton Grid.Row="0"
                         Grid.Column="0"
                         BackgroundColor="Green"
                         HorizontalOptions="Start"
                         VerticalOptions="Start"
                         HeightRequest="200"
                         WidthRequest="200"
                         Margin="10,100,0,10"
                         Source="{Binding Image}"
                         Command="{Binding ChangeImageStateCommand}" />

            <Entry Grid.Row="0"
                   Grid.Column="1"
                   Placeholder="Növény neve"
                   Margin="20,100,0,0"
                   HeightRequest="20"
                   ClearButtonVisibility="WhileEditing"
                   Text="{Binding ItemName}" />

            <Editor Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Placeholder="Növény leírása"
                    Margin="10"
                    HeightRequest="100"
                    Text="{Binding ItemDescription}" />

            <Button Grid.Row="2"
                    Grid.Column="0"
                    Margin="10"
                    Text="Mentés"
                    Command="{Binding EditCommand}" />

            <Button Grid.Row="2"
                    Grid.Column="1"
                    Margin="10"
                    Text="Törlés"
                    BackgroundColor="Red"
                    Command="{Binding DeleteCommand}" />
        </Grid>
        <Grid RowDefinitions="*, auto"
              ColumnDefinitions="*,*"
              IsVisible="{Binding IsImage}">
            <toolkit:CameraView Grid.Row="0"
                                Grid.ColumnSpan="2"
                                x:Name="Camera"
                                IsVisible="{Binding HasNotImage}" />
            <ImageButton Command="{Binding CaptureCommand}"
                         CommandParameter="{x:Reference Camera}"
                         MaximumWidthRequest="80"
                         MaximumHeightRequest="80"
                         MinimumHeightRequest="80"
                         MinimumWidthRequest="80"
                         BorderColor="White"
                         BorderWidth="10"
                         CornerRadius="80"
                         BackgroundColor="Transparent"
                         Grid.Row="1"
                         Grid.Column="1"
                         IsVisible="{Binding HasNotImage}" />
            <ImageButton Command="{Binding PickImageCommand}"
                         MaximumWidthRequest="80"
                         MaximumHeightRequest="80"
                         MinimumHeightRequest="80"
                         MinimumWidthRequest="80"
                         BorderColor="White"
                         BorderWidth="10"
                         CornerRadius="80"
                         BackgroundColor="Red"
                         Grid.Row="1"
                         Grid.Column="0"
                         IsVisible="{Binding HasNotImage}" />
            <Image Grid.ColumnSpan="2"
                   Grid.Row="0"
                   Aspect="AspectFill"
                   HorizontalOptions="Fill"
                   VerticalOptions="Fill"
                   Source="{Binding Image}"
                   IsVisible="{Binding HasImage}" />
            <Grid IsVisible="{Binding HasImage}"
                  Grid.Row="1"
                  Grid.ColumnSpan="2"
                  ColumnDefinitions="*,*"
                  ColumnSpacing="10"
                  Margin="0,20,0,10">
                <Button Text="Új kép"
                        Command="{Binding NewImageCommand}"
                        Grid.Column="0" />
                <Button Text="Rendben"
                        Command="{Binding ChangeImageStateCommand}"
                        Grid.Column="1"
                        IsVisible="{Binding HasImage}" />
            </Grid>
        </Grid>
        <Grid
              Background="{StaticResource BackgroundDark}"
              IsVisible="{Binding IsBusy}">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Label Text="Betöltés"
                       FontSize="20"
                       FontAttributes="Bold"
                       Margin="20"
                       TextColor="{AppThemeBinding Dark={StaticResource SecondaryLight}, Light={StaticResource SecondaryDark}}" />
                <ActivityIndicator Grid.ColumnSpan="2"
                                   Grid.RowSpan="2"
                                   IsRunning="{Binding IsBusy}"
                                   Scale="2">
                </ActivityIndicator>

            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>