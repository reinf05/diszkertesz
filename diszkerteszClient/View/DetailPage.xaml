<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:diszkerteszClient.Models"
             x:Class="diszkerteszClient.View.DetailPage"
             xmlns:viewmodel="clr-namespace:diszkerteszClient.Viewmodels"
             x:DataType="viewmodel:DetailViewModel"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto, Auto, *"
          Background="{AppThemeBinding Dark={StaticResource BackgroundDark}, Light={StaticResource SecondaryDark}}">

        <CollectionView ItemsSource="{Binding FullPlant.Imagepath}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Horizontal"
                                   ItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Image Source="{Binding .}"
                           Style="{StaticResource Thumbnail}"
                           Grid.Column="0" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Spacing="10"
                             HorizontalOptions="Center"
                             Grid.Row="1">
            <Label Text="{Binding FullPlant.Namel}"
                   Style="{StaticResource TextBold}" />
            <Label Text="{Binding FullPlant.Nameh}" />
            <Label Text="{Binding FullPlant.Type}" />
        </VerticalStackLayout>

        <ScrollView Orientation="Vertical"
                    HorizontalOptions="Center"
                    VerticalOptions="Fill"
                    Grid.Row="2">
            <VerticalStackLayout HorizontalOptions="Fill"
                                 VerticalOptions="Start">

                <Label Text="Általános jellemzők"
                       Style="{StaticResource TextBold}" />
                <Label Text="{Binding FullPlant.Description}" />

                <Label Text="Felhasználás"
                       Style="{StaticResource TextBold}" />
                <Label Text="{Binding FullPlant.Usage}" />

                <Label Text="Növényvédelem"
                       Style="{StaticResource TextBold}" />
                <Label Text="{Binding FullPlant.Pathogens}" />

                <Label Text="Szaporítás"
                       Style="{StaticResource TextBold}" />
                <Label Text="{Binding FullPlant.Propagation}" />
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>