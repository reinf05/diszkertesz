<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:diszkerteszClient.Viewmodels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="diszkerteszClient.View.ProfilePage"
             Title="ProfilePage"
             x:DataType="viewmodel:ProfileViewModel"
             xmlns:model="clr-namespace:diszkerteszClient.Models"
             x:Name="Profile_Page">

    <ContentPage.Triggers>
        <DataTrigger
            TargetType="ContentPage"
            Binding="{Binding IsNotLoaded}"
            Value="True">
            <Setter
                Property="Title"
                Value="Azonosítás"/>
        </DataTrigger>
        <DataTrigger
            TargetType="ContentPage"
            Binding="{Binding IsLoaded}"
            Value="True">
            <Setter
                Property="Title"
                Value="Profilom"/>
        </DataTrigger>
    </ContentPage.Triggers>

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior
            EventName="Appearing"
            Command="{Binding BindingContext.LoadUserListCommand, Source={x:Reference Profile_Page}}"/>
    </ContentPage.Behaviors>

    <Grid
        ColumnDefinitions="*"
        RowDefinitions="*">

        <Grid
            Grid.ColumnSpan="1"
            Grid.RowSpan="1"
            RowDefinitions="*,*"
            IsVisible="{Binding IsNotLoaded}">

            <Button
                Grid.Row="0"
                Margin="10"
                Text="Bejelentkezés"
                Command="{Binding SignInCommand}"/>

            <Button
                Grid.Row="1"
                Margin="10"
                Text="Regisztráció"
                Command="{Binding SignUpCommand}"/>

        </Grid>

        <Grid
            Grid.ColumnSpan="1"
            Grid.RowSpan="1"
            IsVisible="{Binding IsLoaded}"
            RowDefinitions="*,auto">

        <CollectionView
                Grid.Row="0"
                SelectionMode="None"
                ItemsSource="{Binding UserItems}">

                <CollectionView.ItemTemplate>
                    <DataTemplate
                    x:DataType="{x:Type model:UserItem}">
                        <VerticalStackLayout Padding="5">

                            <Border
                                HorizontalOptions="Center">
                                <!--Implement gesture recognizer later/ edit page
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer
                                </Border.GestureRecognizers>-->


                                <Grid
                                    ColumnDefinitions="125,200"
                                    Padding="10"
                                    ColumnSpacing="20">
                                    <Image
                                        Source="{Binding Pictureurl}"
                                        Style="{StaticResource Thumbnail}"
                                        Grid.Column="0"/>
                                    <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="10"
                                        VerticalOptions="Center">
                                        <Label Text="{Binding Name}"
                                           Style="{StaticResource TextBold}"/>
                                        <Label Text="{Binding Description}"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>

                </CollectionView.ItemTemplate>

            </CollectionView>

            <HorizontalStackLayout
                Grid.Row="1"
                HorizontalOptions="Center"
                Margin="10"
                Spacing="20">
                <Button
                    Margin="10"
                    Text="Hozzáadás"
                    Command="{Binding GoToAddPageCommand}"/>

                <Button
                    Margin="10"
                    Text="Kijelentkezés"
                    Command="{Binding SignOutCommand}"/>
            </HorizontalStackLayout>
        </Grid>

    </Grid>
</ContentPage>