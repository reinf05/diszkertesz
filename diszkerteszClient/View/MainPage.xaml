<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:diszkerteszClient.Models"
             xmlns:viewmodel="clr-namespace:diszkerteszClient.Viewmodels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="viewmodel:MainViewModel"
             x:Class="diszkerteszClient.View.MainPage"
             Title="{Binding Title}">

    <Grid ColumnDefinitions="*, *"
          RowDefinitions="50, *, Auto"
          BackgroundColor="{StaticResource BackgroundDark}">

        <SearchBar IsVisible="{Binding IsLoaded}"
                   Grid.Row="0"
                   Grid.ColumnSpan="2"
                   Placeholder="Keresés..."
                   Text="{Binding SearchText, Mode=TwoWay}"
                   SearchCommand="{Binding SearchCommand}"
                   CancelButtonColor="Red"
                   x:Name="SearchBar">
            <SearchBar.Behaviors>
                <toolkit:UserStoppedTypingBehavior BindingContext="{Binding Path=BindingContext, Source={x:Reference SearchBar}, x:DataType=SearchBar}"
                                                   Command="{Binding SearchCommand}"
                                                   StoppedTypingTimeThreshold="1500"
                                                   MinimumLengthThreshold="0"
                                                   ShouldDismissKeyboardAutomatically="True" />
            </SearchBar.Behaviors>
        </SearchBar>

        <CollectionView Grid.Row="1"
                        Grid.RowSpan="2"
                        Grid.ColumnSpan="2"
                        ItemsSource="{Binding FilteredPlants}"
                        SelectionMode="None"
                        RemainingItemsThreshold="3"
                        RemainingItemsThresholdReachedCommand="{Binding GetMorePageCommand}">

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="{x:Type model:Plant}">
                    <VerticalStackLayout Padding="5">

                        <Border HorizontalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}}, Path=GoToDetailsCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>

                            <Grid ColumnDefinitions="125,200"
                                  Padding="10"
                                  ColumnSpacing="20">
                                <Image Source="{Binding Imagepath, StringFormat='{0}1.jpeg'}"
                                       Style="{StaticResource Thumbnail}"
                                       Grid.Column="0" />
                                <VerticalStackLayout Grid.Column="1"
                                                     Spacing="10"
                                                     VerticalOptions="Center">
                                    <Label Text="{Binding Namel}"
                                           Style="{StaticResource TextBold}" />
                                    <Label Text="{Binding Nameh}" />
                                    <Label Text="{Binding Type}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Button Grid.Row="2"
                Grid.ColumnSpan="2"
                Margin="10"
                Text="Betöltés"
                Command="{Binding GetFirstPageCommand}"
                IsVisible="{Binding IsNotLoaded}">

        </Button>

        <Grid Grid.Row="1"
              Grid.RowSpan="2"
              Grid.ColumnSpan="2"
              Background="{StaticResource BackgroundDark}"
              IsVisible="{Binding IsBusy}">
            <VerticalStackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center">

                <Label Text="Betöltés"
                       FontSize="20"
                       FontAttributes="Bold"
                       Margin="20"
                       TextColor="{AppThemeBinding Dark={StaticResource SecondaryLight}, Light={StaticResource SecondaryDark}}" />
                <ActivityIndicator Grid.ColumnSpan="2"
                                   Grid.RowSpan="2"
                                   IsRunning="{Binding IsBusy}"
                                   Scale="2">
                </ActivityIndicator>

            </VerticalStackLayout>
        </Grid>
    </Grid>

</ContentPage>
